<Window x:Class="TransportProblemApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Транспортная задача - Оптимальное планирование перевозок"
        Height="750" Width="1024"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ЗАГОЛОВОК С ЛОГОТИПОМ -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Border Width="48" Height="48" Background="{StaticResource AccentBrush}" 
                    CornerRadius="8" Margin="0,0,12,0">
                <TextBlock Text="🚚" FontSize="28" HorizontalAlignment="Center" 
                           VerticalAlignment="Center"/>
            </Border>

            <StackPanel>
                <TextBlock Text="ТРАНСПОРТНАЯ ЗАДАЧА" 
                           Style="{StaticResource TitleStyle}" FontSize="16"/>
                <TextBlock Text="Оптимальное планирование перевозок • Методы северо-западного угла и минимальных элементов" 
                           Style="{StaticResource SecondaryTextStyle}"/>
            </StackPanel>
        </StackPanel>

        <!-- ПАНЕЛЬ УПРАВЛЕНИЯ -->
        <Border Grid.Row="1" Style="{StaticResource ControlPanelStyle}">
            <WrapPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                    <TextBlock Text="Метод решения:" 
                               Style="{StaticResource BodyTextStyle}" 
                               VerticalAlignment="Center" 
                               Margin="0,0,8,0"/>
                    <ComboBox x:Name="cmbMethod" Width="220" SelectedIndex="0">
                        <ComboBoxItem Content="Метод северо-западного угла"/>
                        <ComboBoxItem Content="Метод минимальных элементов"/>
                    </ComboBox>
                </StackPanel>

                <Button x:Name="btnCalculate" 
                        Content="РАССЧИТАТЬ" 
                        Style="{StaticResource PrimaryButtonStyle}" 
                        Width="130"
                        Click="BtnCalculate_Click"/>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" 
                           Margin="8,4"/>

                <Button x:Name="btnLoadFile" 
                        Content="📂 Загрузить из файла" 
                        Style="{StaticResource SecondaryButtonStyle}" 
                        Width="150"
                        Click="BtnLoadFile_Click"/>

                <Button x:Name="btnExportExcel" 
                        Content="📊 Экспорт в Excel" 
                        Style="{StaticResource SecondaryButtonStyle}" 
                        Width="140"
                        Click="BtnExportExcel_Click"/>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" 
                           Margin="8,4"/>

                <Button x:Name="btnExample" 
                        Content="📋 Пример" 
                        Style="{StaticResource SecondaryButtonStyle}" 
                        Width="100"
                        Click="BtnExample_Click"/>

                <Button x:Name="btnClear" 
                        Content="🗑 Очистить" 
                        Style="{StaticResource SecondaryButtonStyle}" 
                        Width="100"
                        Click="BtnClear_Click"/>
            </WrapPanel>
        </Border>

        <!-- ОСНОВНОЕ СОДЕРЖИМОЕ (ВКЛАДКИ) -->
        <TabControl Grid.Row="2">
            <!-- ВКЛАДКА ВВОДА ДАННЫХ -->
            <TabItem Header="📝 Ввод данных">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,12,8,8">

                        <GroupBox Header="⚙ Настройка размеров задачи">
                            <StackPanel Orientation="Horizontal" Margin="4">
                                <TextBlock Text="Количество поставщиков:" 
                                           Style="{StaticResource BodyTextStyle}" 
                                           Width="160" 
                                           VerticalAlignment="Center"/>
                                <TextBox x:Name="txtSuppliers" 
                                         Text="3" 
                                         Width="60" 
                                         Margin="0,0,24,0"
                                         TextAlignment="Center"/>

                                <TextBlock Text="Количество потребителей:" 
                                           Style="{StaticResource BodyTextStyle}" 
                                           Width="160" 
                                           VerticalAlignment="Center"/>
                                <TextBox x:Name="txtConsumers" 
                                         Text="4" 
                                         Width="60" 
                                         Margin="0,0,24,0"
                                         TextAlignment="Center"/>

                                <Button x:Name="btnResize" 
                                        Content="Применить" 
                                        Style="{StaticResource SecondaryButtonStyle}" 
                                        Width="100"
                                        Click="BtnResize_Click"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="💰 Матрица стоимости перевозок">
                            <StackPanel>
                                <TextBlock Text="Введите стоимость перевозки единицы товара от поставщика к потребителю" 
                                           Style="{StaticResource SecondaryTextStyle}" 
                                           Margin="0,0,0,8"/>
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" 
                                              MaxHeight="350"
                                              VerticalScrollBarVisibility="Disabled">
                                    <ItemsControl x:Name="costsMatrix">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Vertical"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </GroupBox>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <GroupBox Header="📦 Запасы поставщиков" Grid.Column="0">
                                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="suppliesList">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Vertical"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </ScrollViewer>
                            </GroupBox>

                            <GroupBox Header="🎯 Потребности потребителей" Grid.Column="2">
                                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="demandsList">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Vertical"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </ScrollViewer>
                            </GroupBox>
                        </Grid>

                        <Border Background="{StaticResource SurfaceBrush}" 
                                Padding="12" CornerRadius="4" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="ℹ Формат файла для загрузки:" 
                                           Style="{StaticResource BodyTextStyle}" 
                                           FontWeight="Bold" 
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="1 строка: количество_поставщиков количество_потребителей" 
                                           Style="{StaticResource SecondaryTextStyle}"/>
                                <TextBlock Text="2-N строка: матрица стоимости (по строкам)" 
                                           Style="{StaticResource SecondaryTextStyle}"/>
                                <TextBlock Text="Строка N+1: запасы поставщиков (через пробел)" 
                                           Style="{StaticResource SecondaryTextStyle}"/>
                                <TextBlock Text="Строка N+2: потребности потребителей (через пробел)" 
                                           Style="{StaticResource SecondaryTextStyle}"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ВКЛАДКА РЕЗУЛЬТАТОВ -->
            <TabItem Header="📊 Результаты" x:Name="tabResults">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="txtMethodName" 
                               Grid.Row="0"
                               Style="{StaticResource TitleStyle}" 
                               Margin="0,0,0,12"/>

                    <GroupBox Header="📋 Опорный план перевозок" Grid.Row="1">
                        <DataGrid x:Name="dgResults" 
                                  MinHeight="150" 
                                  MaxHeight="250"
                                  IsReadOnly="True"/>
                    </GroupBox>

                    <Border Grid.Row="2" Style="{StaticResource SuccessBorderStyle}">
                        <TextBlock x:Name="txtTotalCost" 
                                   Style="{StaticResource SuccessTextStyle}"/>
                    </Border>

                    <TextBlock x:Name="txtBalance" 
                               Grid.Row="3"
                               Style="{StaticResource HeaderStyle}" 
                               Margin="0,8,0,8"/>

                    <!-- ОКНО ПОШАГОВОГО РЕШЕНИЯ -->
                    <GroupBox Header="📝 Пошаговое решение" Grid.Row="4">
                        <ScrollViewer x:Name="stepsScrollViewer" 
                          VerticalScrollBarVisibility="Auto" 
                          HorizontalScrollBarVisibility="Auto"
                          Background="White">
                            <TextBlock x:Name="txtSteps" 
                           FontFamily="Consolas" 
                           FontSize="11"
                           TextWrapping="Wrap"
                           Background="Transparent"
                           Margin="8"
                           Text=""/>
                        </ScrollViewer>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- СТАТУСНАЯ СТРОКА -->
        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" 
                           Text="✅ Готов к работе. Введите данные и нажмите «Рассчитать»"
                           Style="{StaticResource SecondaryTextStyle}"/>
            </StatusBarItem>
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="Версия 1.0 | Транспортная задача" 
                           Style="{StaticResource SecondaryTextStyle}"/>
            </StatusBarItem>
        </StatusBar>

    </Grid>
</Window>