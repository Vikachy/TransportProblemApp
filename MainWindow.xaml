<Window x:Class="TransportProblemApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Транспортная задача - Решение методом северо-западного угла"
        Height="750" Width="1024"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Логотип и заголовок -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="🚚" FontSize="28" Margin="0,0,8,0"/>
            <StackPanel>
                <TextBlock Text="ТРАНСПОРТНАЯ ЗАДАЧА" FontSize="14" FontWeight="Bold"/>
                <TextBlock Text="Оптимальное планирование перевозок" FontSize="10" 
                           Foreground="{StaticResource SecondaryTextBrush}"/>
            </StackPanel>
        </StackPanel>

        <!-- Панель управления -->
        <Border Grid.Row="1" Background="#F5F5F5" Padding="12" Margin="0,0,0,16" CornerRadius="4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Метод решения:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="cmbMethod" Width="200" SelectedIndex="0">
                    <ComboBoxItem Content="Метод северо-западного угла"/>
                    <ComboBoxItem Content="Метод минимальных элементов"/>
                </ComboBox>
                <Button x:Name="btnCalculate" Content="РАССЧИТАТЬ" 
                        Style="{StaticResource AccentButton}" Width="120"
                        Click="BtnCalculate_Click"/>
                <Button x:Name="btnClear" Content="Очистить" Width="80" Click="BtnClear_Click"/>
                <Button x:Name="btnExample" Content="Пример" Width="80" Click="BtnExample_Click"/>
            </StackPanel>
        </Border>

        <!-- Основное содержимое -->
        <TabControl Grid.Row="2">
            <!-- Вкладка ввода данных -->
            <TabItem Header=" Ввод данных">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,0,16">
                        <!-- Размеры матрицы -->
                        <GroupBox Header="Настройка размеров">
                            <StackPanel Orientation="Horizontal" Margin="8">
                                <TextBlock Text="Количество поставщиков:" Width="160"/>
                                <TextBox x:Name="txtSuppliers" Text="3" Width="60" Margin="0,0,16,0"/>
                                <TextBlock Text="Количество потребителей:" Width="160"/>
                                <TextBox x:Name="txtConsumers" Text="5" Width="60" Margin="0,0,16,0"/>
                                <Button x:Name="btnResize" Content="Применить" Click="BtnResize_Click" Width="100"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Матрица тарифов -->
                        <GroupBox Header="Матрица тарифов (стоимость перевозки)">
                            <StackPanel>
                                <TextBlock Text="Введите стоимость перевозки от поставщика к потребителю" 
                                           Style="{StaticResource HeaderStyle}" Margin="0,0,0,8"/>
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" MaxHeight="350">
                                    <ItemsControl x:Name="costsMatrix">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Vertical"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </GroupBox>

                        <!-- Запасы и потребности -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="19*"/>
                                <ColumnDefinition Width="466*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="485*"/>
                            </Grid.ColumnDefinitions>

                            <GroupBox Header="Запасы поставщиков" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,16">
                                <ItemsControl x:Name="suppliesList">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Vertical"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </GroupBox>

                            <GroupBox Header="Потребности потребителей" Grid.Column="3" Margin="0,0,0,16">
                                <ItemsControl x:Name="demandsList">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Vertical"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </GroupBox>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Вкладка результатов -->
            <TabItem Header=" Результаты" x:Name="tabResults">
                <ScrollViewer>
                    <StackPanel Margin="8">
                        <TextBlock x:Name="txtMethodName" Style="{StaticResource TitleStyle}"/>

                        <GroupBox Header="📋 Опорный план перевозок">
                            <DataGrid x:Name="dgResults" AutoGenerateColumns="True" 
                                     CanUserAddRows="False" CanUserDeleteRows="False"
                                     MinHeight="200" MaxHeight="400"
                                     FontFamily="Tw Cen MT" FontSize="11"/>
                        </GroupBox>

                        <Border Background="#E8F5E9" Padding="12" CornerRadius="4" Margin="0,0,0,8">
                            <TextBlock x:Name="txtTotalCost" FontSize="14" FontWeight="Bold" 
                                       Foreground="#2E7D32"/>
                        </Border>

                        <TextBlock x:Name="txtBalance" Style="{StaticResource HeaderStyle}" Margin="0,0,0,8"/>

                        <GroupBox Header=" Пошаговое решение">
                            <ScrollViewer MaxHeight="250">
                                <TextBlock x:Name="txtSteps" FontSize="10" TextWrapping="Wrap" 
                                           FontFamily="Consolas" Margin="8"/>
                            </ScrollViewer>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Статусбар -->
        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" Text="Готов к работе. Введите данные и нажмите 'Рассчитать'"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>